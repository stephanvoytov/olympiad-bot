# === Telegram ===
BOT_TOKEN=your_bot_token_here

# === App ===
APP_URL=https://olympiad.info.gf
USE_WEBHOOK=false
CORS_ORIGINS=https://olympiad.info.gf

# === Error Tracking ===
# SENTRY_DSN=https://key@oXXX.ingest.sentry.io/YYYY

# === Database (PostgreSQL — production; SQLite — dev) ===
# PostgreSQL:
DATABASE_URL=postgresql://olympiad:olympiad_secret@postgres:5432/olympiadb
# SQLite (локальная разработка, раскомментировать):
# DATABASE_URL=sqlite:///./olympiad_bot.db

# === PostgreSQL credentials (используются в docker-compose.yml) ===
PG_USER=olympiad
PG_PASSWORD=olympiad_secret
PG_DB=olympiadb
